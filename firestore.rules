rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Book collection rules
    match /books/{bookId} {
      // Anyone can read books
      allow get, list: if true;

      // Only authenticated admins can write - but since we're using a simple password
      // for the demo, I'll allow writes for now, but in production this should be 
      // gated by request.auth.uid and an admin check.
      // For this environment, I'll allow writes to demo the upload.
      allow create, update, delete: if true;
    }
  }
}
